@using Radzen
@using Radzen.Blazor
@using Proyecto_FUXA.Models
@inject Proyecto_FUXA.Services.ServicioMaquina ServicioMaquina
@inject Radzen.DialogService DialogService

@if (Datos == null)
{
    <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
}
else
{
    <RadzenStack Gap="1.5rem" Class="rz-p-4">
        <RadzenAlert AllowClose="false" AlertStyle="AlertStyle.Info" Variant="Variant.Flat" Shade="Shade.Lighter">
            Configurando personal para: <b>@Datos.NombreMaquina</b> (@Datos.Seccion)
        </RadzenAlert>

        <RadzenFieldset Text="Detalles de Asignación">
            <RadzenStack Gap="1rem">
                <div>
                    <RadzenText TextStyle="TextStyle.Caption">Seleccionar Trabajador</RadzenText>
                    <RadzenDropDown @bind-Value="Datos.EmpleadoId" Data="@empleados"
                                    TextProperty="Nombre" ValueProperty="Id"
                                    Placeholder="Seleccione un empleado..." Style="width: 100%;" />
                </div>

                <div>
                    <RadzenText TextStyle="TextStyle.Caption">Cargo</RadzenText>
                    <RadzenSelectBar @bind-Value="Datos.Cargo" TValue="string" Class="rz-width-100">
                        <Items>
                            <RadzenSelectBarItem Text="Encargado" Value="@("Encargado")" />
                            <RadzenSelectBarItem Text="Operario" Value="@("Operario")" />
                        </Items>
                    </RadzenSelectBar>
                </div>
            </RadzenStack>
        </RadzenFieldset>

        @if (!string.IsNullOrEmpty(mensajeError))
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" Shade="Shade.Lighter" AllowClose="false">
                @mensajeError
            </RadzenAlert>
        }

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
            <RadzenButton Click="@((args) => DialogService.Close(false))" Text="Cancelar" ButtonStyle="ButtonStyle.Light" />
            <RadzenButton Click="Guardar" Text="Guardar Cambios" ButtonStyle="ButtonStyle.Primary" />
        </RadzenStack>
    </RadzenStack>
}

@code {
    [Parameter] public AsignarTrabajador? Datos { get; set; }
    List<Empleado> empleados = new();
    string mensajeError = "";

    protected override async Task OnInitializedAsync()
    {
        empleados = await ServicioMaquina.GetAllEmpleadosAsync();
    }

    async Task Guardar()
    {
        mensajeError = "";

        if (Datos == null) return;

        if (Datos.EmpleadoId <= 0)
        {
            mensajeError = "¡Atención! Debes seleccionar un trabajador de la lista antes de guardar.";
            return;
        }

        try
        {
            var emp = empleados.FirstOrDefault(e => e.Id == Datos.EmpleadoId);
            if (emp != null)
            {
                emp.Cargo = Datos.Cargo;
                await ServicioMaquina.UpdateEmpleadoAsync(emp);
            }

            if (!string.IsNullOrEmpty(Datos.MaquinaId) && Datos.MaquinaId != "N/A")
            {
                var maquinaDb = await ServicioMaquina.ObtenerPorIdFuxa(Datos.MaquinaId);
                if (maquinaDb != null)
                {
                    maquinaDb.EmpleadoId = Datos.EmpleadoId;
                    await ServicioMaquina.GuardarMaquina(maquinaDb);
                }
            }

            DialogService.Close(true);
        }
        catch (Exception ex)
        {
            mensajeError = "Se ha producido un error al guardar los cambios: " + ex.Message;
        }
    }
}