@page "/ciclos-maquina/{machineId:int}"
@using Proyecto_FUXA.Models
@using Proyecto_FUXA.Services

@inject ServicioMaquina MachineService
@inject NavigationManager Navigation

<h3>Registrar ciclos de máquina</h3>

@if (machine == null)
{
    <p>Cargando máquina...</p>
}
else
{
    <div style="border:1px solid #ccc;padding:20px;width:400px">
        <p><b>Máquina:</b> @machine.Nombre</p>
        <p><b>Sección:</b> @machine.NombreSeccion</p>
        <p><b>Objetivo ciclos:</b> @machine.CiclosObjetivo</p>

        <hr />

        <label>Ciclos reales:</label>
        <input type="number" class="form-control" @bind="realCycles" />

        <br />

        <button class="btn btn-primary" @onclick="Guardar">Registrar ciclos</button>
    </div>
}

@code {
    [Parameter]
    public int machineId { get; set; }

    private Maquina? machine;
    private int realCycles;

    protected override async Task OnInitializedAsync()
    {
        machine = await MachineService.GetByIdAsync(machineId);
    }

    private async Task Guardar()
    {
        await MachineService.AddCycleAsync(machineId, realCycles);
        Navigation.NavigateTo($"/dashboard-maquina/{machineId}");
    }
}
