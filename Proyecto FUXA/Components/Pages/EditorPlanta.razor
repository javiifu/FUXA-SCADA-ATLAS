@page "/planta-editor"
@using Proyecto_FUXA.Models
@using Proyecto_FUXA.Services
@rendermode InteractiveServer

@inject ServicioPlantaVisual ServicioPlantaVisual
@inject ServicioMaquina ServicioMaquina

<h3>Editor visual de planta</h3>

<div class="editor-planta-grid">
    <div>
        <div class="d-flex justify-content-between align-items-center mb-2">
            <strong>Lienzo</strong>
            <div class="d-flex gap-2">
                <button class="btn btn-primary btn-sm" @onclick="AgregarRectangulo">+ Rectángulo</button>
                <button class="btn btn-primary btn-sm" @onclick="AgregarCirculo">+ Círculo</button>
                <button class="btn btn-primary btn-sm" @onclick="AgregarLinea">+ Línea</button>
            </div>
        </div>

        <div class="planta-canvas"
            @onmousemove="MoverArrastre"
            @onmouseup="FinalizarArrastre"
            @onmouseleave="FinalizarArrastre">
            <svg class="planta-canvas-lineas">
                @foreach (var objeto in objetos.Where(x => x.Tipo == "Linea"))
                {
                    <line class="planta-linea @(objeto.Id == selectedId ? "selected" : string.Empty)"
                          x1="@objeto.PosX"
                          y1="@objeto.PosY"
                          x2="@(objeto.PosX + objeto.Width)"
                          y2="@(objeto.PosY + objeto.Height)"
                          stroke="@NormalizarColorHex(objeto.ColorHex)"
                          @onmousedown="@((e) => IniciarArrastre(objeto.Id, e))"
                          @onclick="@(() => Seleccionar(objeto.Id))" />
                }
            </svg>

            @foreach (var objeto in objetos.Where(x => x.Tipo != "Linea"))
            {
                <div class="planta-objeto @(GetClaseObjeto(objeto)) @(objeto.Id == selectedId ? "selected" : string.Empty)"
                     style="@BuildObjectStyle(objeto)"
                     title="@objeto.Nombre"
                     @onmousedown="@((e) => IniciarArrastre(objeto.Id, e))"
                     @onclick="@(() => Seleccionar(objeto.Id))">
                    <div class="planta-objeto-titulo">@objeto.Nombre</div>
                    @if (!string.IsNullOrWhiteSpace(objeto.Maquina?.Nombre))
                    {
                        <div class="planta-objeto-subtitulo">@objeto.Maquina.Nombre</div>
                    }
                </div>
            }
        </div>
    </div>

    <div class="planta-editor-panel">
        <h5>Propiedades</h5>

        @if (seleccionado is null)
        {
            <p class="text-muted">Selecciona una forma para editar sus propiedades.</p>
        }
        else
        {
            <div class="mb-2">
                <label class="form-label">Tipo</label>
                <input class="form-control" value="@seleccionado.Tipo" readonly />
            </div>

            <div class="mb-2">
                <label class="form-label">Nombre</label>
                <input class="form-control" @bind="seleccionado.Nombre" />
            </div>

            <div class="row g-2">
                <div class="col-6">
                    <label class="form-label">@(EsLineaSeleccionada ? "X1" : "X")</label>
                    <input type="number" class="form-control" @bind="seleccionado.PosX" />
                </div>
                <div class="col-6">
                    <label class="form-label">@(EsLineaSeleccionada ? "Y1" : "Y")</label>
                    <input type="number" class="form-control" @bind="seleccionado.PosY" />
                </div>
                <div class="col-6">
                    <label class="form-label">@(EsLineaSeleccionada ? "Delta X" : "Ancho")</label>
                    <input type="number" class="form-control" @bind="seleccionado.Width" />
                </div>
                <div class="col-6">
                    <label class="form-label">@(EsLineaSeleccionada ? "Delta Y" : "Alto")</label>
                    <input type="number" class="form-control" @bind="seleccionado.Height" />
                </div>
            </div>



            <div class="mb-3">
                <label class="form-label">Máquina asociada</label>
                <select class="form-select" @bind="selectedMaquinaId">
                    <option value="">-- Sin máquina --</option>
                    @foreach (var maquina in maquinas)
                    {
                        <option value="@maquina.Id">@maquina.Nombre</option>
                    }
                </select>
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-success" @onclick="GuardarSeleccion">Guardar</button>
                <button class="btn btn-outline-danger" @onclick="EliminarSeleccion">Eliminar</button>
            </div>
        }
    </div>
</div>

@code {
    private List<PlantaObjetoVisual> objetos = new();
    private List<Maquina> maquinas = new();
    private PlantaObjetoVisual? seleccionado;
    private int? selectedId;
    private int? selectedMaquinaId;
    private int? draggingId;
    private bool dragConMovimiento;
    private int dragStartClientX;
    private int dragStartClientY;
    private int dragStartPosX;
    private int dragStartPosY;

    private const int CanvasWidth = 1200;
    private const int CanvasHeight = 520;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatosAsync();
    }

    private async Task CargarDatosAsync()
    {
        objetos = await ServicioPlantaVisual.GetAllAsync();
        maquinas = await ServicioMaquina.GetAllAsync();
    }

    private async Task AgregarRectangulo()
    {
        var nombre = $"Rectángulo {objetos.Count(x => x.Tipo == "Rectangulo") + 1}";
        var nuevo = await ServicioPlantaVisual.AddAsync("Rectangulo", nombre);

        await CargarDatosAsync();
        Seleccionar(nuevo.Id);
    }

    private async Task AgregarCirculo()
    {
        var nombre = $"Círculo {objetos.Count(x => x.Tipo == "Circulo") + 1}";
        var nuevo = await ServicioPlantaVisual.AddAsync("Circulo", nombre);

        await CargarDatosAsync();
        Seleccionar(nuevo.Id);
    }

    private async Task AgregarLinea()
    {
        var nombre = $"Línea {objetos.Count(x => x.Tipo == "Linea") + 1}";
        var nuevo = await ServicioPlantaVisual.AddAsync("Linea", nombre);

        await CargarDatosAsync();
        Seleccionar(nuevo.Id);
    }

    private void Seleccionar(int id)
    {
        selectedId = id;
        seleccionado = objetos.FirstOrDefault(x => x.Id == id);
        selectedMaquinaId = seleccionado?.MaquinaId;
    }

    private async Task GuardarSeleccion()
    {
        if (seleccionado is null)
        {
            return;
        }

        if (!EsLineaSeleccionada)
        {
            seleccionado.Width = Math.Max(20, seleccionado.Width);
            seleccionado.Height = Math.Max(20, seleccionado.Height);
        }

        seleccionado.ColorHex = NormalizarColorHex(seleccionado.ColorHex);
        seleccionado.Nombre = string.IsNullOrWhiteSpace(seleccionado.Nombre)
            ? $"{seleccionado.Tipo} {seleccionado.Id}"
            : seleccionado.Nombre.Trim();

        await ServicioPlantaVisual.UpdateAsync(seleccionado);
        await ServicioPlantaVisual.VincularMaquinaAsync(seleccionado.Id, selectedMaquinaId);

        await CargarDatosAsync();
        Seleccionar(seleccionado.Id);
    }

    private async Task EliminarSeleccion()
    {
        if (selectedId is null)
        {
            return;
        }

        await ServicioPlantaVisual.DeleteAsync(selectedId.Value);
        await CargarDatosAsync();

        seleccionado = null;
        selectedId = null;
        selectedMaquinaId = null;
    }

    private void IniciarArrastre(int id, MouseEventArgs e)
    {
        if (e.Button != 0)
        {
            return;
        }

        var objeto = objetos.FirstOrDefault(x => x.Id == id);
        if (objeto is null)
        {
            return;
        }

        Seleccionar(id);
        draggingId = id;
        dragConMovimiento = false;
        dragStartClientX = (int)e.ClientX;
        dragStartClientY = (int)e.ClientY;
        dragStartPosX = objeto.PosX;
        dragStartPosY = objeto.PosY;
    }

    private void MoverArrastre(MouseEventArgs e)
    {
        if (draggingId is null)
        {
            return;
        }

        var objeto = objetos.FirstOrDefault(x => x.Id == draggingId.Value);
        if (objeto is null)
        {
            return;
        }

        var deltaX = (int)e.ClientX - dragStartClientX;
        var deltaY = (int)e.ClientY - dragStartClientY;
        if (deltaX == 0 && deltaY == 0)
        {
            return;
        }

        var nuevoX = dragStartPosX + deltaX;
        var nuevoY = dragStartPosY + deltaY;

        (objeto.PosX, objeto.PosY) = LimitarPosicionEnLienzo(objeto, nuevoX, nuevoY);
        dragConMovimiento = true;
    }

    private async Task FinalizarArrastre()
    {
        if (draggingId is null)
        {
            return;
        }

        var objeto = objetos.FirstOrDefault(x => x.Id == draggingId.Value);
        var huboMovimiento = dragConMovimiento;

        draggingId = null;
        dragConMovimiento = false;

        if (!huboMovimiento || objeto is null)
        {
            return;
        }

        await ServicioPlantaVisual.UpdateAsync(objeto);
    }


    private static string NormalizarColorHex(string? color)
    {
        if (string.IsNullOrWhiteSpace(color))
        {
            return "#2f80ed";
        }

        return color.StartsWith('#') ? color : $"#{color}";
    }

    private static string BuildObjectStyle(PlantaObjetoVisual objeto)
    {
        return $"left:{objeto.PosX}px;top:{objeto.PosY}px;width:{Math.Max(20, objeto.Width)}px;height:{Math.Max(20, objeto.Height)}px;background:{NormalizarColorHex(objeto.ColorHex)};";
    }

    private bool EsLineaSeleccionada => seleccionado?.Tipo == "Linea";

    private static (int X, int Y) LimitarPosicionEnLienzo(PlantaObjetoVisual objeto, int posX, int posY)
    {
        if (objeto.Tipo == "Linea")
        {
            var minX = Math.Min(posX, posX + objeto.Width);
            var maxX = Math.Max(posX, posX + objeto.Width);
            var minY = Math.Min(posY, posY + objeto.Height);
            var maxY = Math.Max(posY, posY + objeto.Height);

            if (minX < 0)
            {
                posX -= minX;
            }
            else if (maxX > CanvasWidth)
            {
                posX -= maxX - CanvasWidth;
            }

            if (minY < 0)
            {
                posY -= minY;
            }
            else if (maxY > CanvasHeight)
            {
                posY -= maxY - CanvasHeight;
            }

            return (posX, posY);
        }

        var ancho = Math.Max(20, objeto.Width);
        var alto = Math.Max(20, objeto.Height);
        var x = Math.Clamp(posX, 0, CanvasWidth - ancho);
        var y = Math.Clamp(posY, 0, CanvasHeight - alto);

        return (x, y);
    }

    private static string GetClaseObjeto(PlantaObjetoVisual objeto)
    {
        return objeto.Tipo switch
        {
            "Circulo" => "planta-objeto-circulo",
            _ => "planta-objeto-rectangulo"
        };
    }
}
