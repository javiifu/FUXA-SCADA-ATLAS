@page "/dashboard-maquina/{machineId:int}"
@page "/dashboard-maquina"
@using System.Linq
@using Proyecto_FUXA.Models
@using Proyecto_FUXA.Services

@inject ServicioMaquina MachineService
@inject ServicioProductividad ProductivityService

<h3>Dashboard Máquina</h3>

@if (machine == null)
{
    <p>@mensajeCarga</p>
}
else
{
    var last = machine.Producciones.OrderByDescending(p => p.FechaRegistro).FirstOrDefault();
    var realCycles = last?.CiclosReales ?? 0;
    var productivity = ProductivityService.Calculate(realCycles, machine.CiclosObjetivo);

    <div style="padding:20px;border:1px solid #ccc;background:@GetColor(machine.EstadoActual?.Nombre)">

        <h4>@machine.Nombre</h4>

        <p><b>Sección:</b> @machine.NombreSeccion</p>
        <p><b>Objeto FUXA:</b> @(machine.IdentificadorObjetoFuxa ?? "-")</p>
        <p><b>Estado:</b> @machine.EstadoActual?.Nombre (@machine.EstadoActualId)</p>
        <p><b>Objetivo ciclos:</b> @machine.CiclosObjetivo</p>
        <p><b>Ciclos reales:</b> @realCycles</p>
        <p><b>Productividad:</b> @productivity %</p>

    </div>
}

@code {
    [Parameter]
    public int? machineId { get; set; }

    [SupplyParameterFromQuery(Name = "fuxaObjectId")]
    public string? fuxaObjectId { get; set; }

    private Maquina? machine;
    private string mensajeCarga = "Cargando...";

    protected override async Task OnParametersSetAsync()
    {
        machine = null;

        if (machineId.HasValue)
        {
            machine = await MachineService.GetByIdAsync(machineId.Value);
        }
        else if (!string.IsNullOrWhiteSpace(fuxaObjectId))
        {
            machine = await MachineService.GetByIdentificadorObjetoFuxaAsync(fuxaObjectId);
        }

        if (machine is null)
        {
            mensajeCarga = string.IsNullOrWhiteSpace(fuxaObjectId)
                ? "No se encontró la máquina solicitada."
                : $"No existe una máquina vinculada al objeto FUXA '{fuxaObjectId}'.";
        }
    }

    string GetColor(string? status)
    {
        return status switch
        {
            "Activo" => "#b6fcb6",
            "Incidencia" => "#ffd966",
            "Parado" => "#ffb3b3",
            _ => "white"
        };
    }
}
