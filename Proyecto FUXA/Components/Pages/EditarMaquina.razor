@page "/editar-maquina/{IdFuxa}"
@using Proyecto_FUXA.Models
@using Proyecto_FUXA.Services

@rendermode InteractiveServer

@inject ServicioMaquina MachineService
@inject NavigationManager Navigation

<h3>Editar Máquina</h3>

@if (machine == null)
{
    <p>Cargando máquina...</p>
}
else
{
    <div style="border-radius: 5px; border:1px solid #ccc;padding:20px;width:500px">
        <div>
            <label>Nombre</label><br />
            <input class="form-control" @bind="machine.Nombre" />
        </div>

        <div>
            <label>ID Fuxa</label><br/>
            <input class="form-control" @bind="machine.IdFuxa" disabled/>
        </div>

        <br />

        <div>
            <label>Número de Orden</label><br />
            <input type="number" class="form-control" @bind="machine.NumeroOrden" />
        </div>

        <br />

        <div>
            <label>Sección</label><br />
            <input class="form-control" @bind="machine.NombreSeccion" />
        </div>

        <br />

        <div>
            <label>Objetivo de ciclos</label><br />
            <input type="number" class="form-control" @bind="machine.CiclosObjetivo" />
        </div>

        <br />

        <div>
            <label>Estado</label><br />
            <select class="form-control" @bind="machine.EstadoActualId">
                <option value="1">Activa</option>
                <option value="2">Incidencia</option>
                <option value="3">Parada</option>
            </select>
        </div>

        <br />

        <div>
            <label>Activa</label>
            <input type="checkbox" @bind="machine.EstaActivo" />
        </div>

        <br />

        <button class="btn btn-primary" @onclick="Guardar">Guardar cambios</button>
        <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
    </div>
}

@code {
    [Parameter]
    public String IdFuxa { get; set; }

    private Maquina? machine;

    protected override async Task OnInitializedAsync()
    {
        machine = await MachineService.ObtenerPorIdFuxa(IdFuxa);

        if (machine == null)
        {
            machine = new Maquina
            {
                IdFuxa = IdFuxa,
                Nombre = "Nueva Máquina",
                FechaCreacion = DateTime.Now,
                EstaActivo = true,
                EstadoActualId = 1
            };
        }
    }

    private async Task Guardar()
    {
        if (machine is null)return;

        machine.FechaActualizacion = DateTime.Now;

        await MachineService.GuardarMaquina(machine);
        Navigation.NavigateTo("/maquinas");
    }

    private void Cancelar()
    {
        Navigation.NavigateTo("/maquinas");
    }
}
