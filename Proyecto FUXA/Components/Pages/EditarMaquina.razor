@page "/editar-maquina/{machineId:int}"
@using Proyecto_FUXA.Services

@inject ServicioMaquina MachineService
@inject NavigationManager Navigation

<h3>Editar Máquina</h3>

@if (machine == null)
{
    <p>Cargando máquina...</p>
}
else
{
    <div style="border:1px solid #ccc;padding:20px;width:500px">

        <div>
            <label>Nombre</label><br />
            <input class="form-control" @bind="machine.nombre" />
        </div>

        <br />

        <div>
            <label>Número de Orden</label><br />
            <input class="form-control" @bind="machine.OrderNumber" />
        </div>

        <br />

        <div>
            <label>Sección</label><br />
            <input class="form-control" @bind="machine.SectionName" />
        </div>

        <br />

        <div>
            <label>Objetivo de ciclos</label><br />
            <input type="number" class="form-control" @bind="machine.TargetCycles" />
        </div>

        <br />

        <div>
            <label>Estado</label><br />
            <select class="form-control" @bind="machine.CurrentStatusId">
                <option value="1">Activa</option>
                <option value="2">Incidencia</option>
                <option value="3">Parada</option>
            </select>
        </div>

        <br />

        <div>
            <label>Activa</label>
            <input type="checkbox" @bind="machine.IsActive" />
        </div>

        <br />

        <button class="btn btn-primary" @onclick="Guardar">
            Guardar cambios
        </button>

        <button class="btn btn-secondary" @onclick="Cancelar">
            Cancelar
        </button>

    </div>
}

@code {

    [Parameter]
    public int machineId { get; set; }

    Maquinas? machine;

    protected override async Task OnInitializedAsync()
    {
        var machines = await MachineService.GetMachinesAsync();
        machine = machines.FirstOrDefault(x => x.Id == machineId);
    }

    async Task Guardar()
    {
        if (machine != null)
        {
            machine.UpdatedAt = DateTime.UtcNow;

            await MachineService.UpdateAsync(machine);

            Navigation.NavigateTo("/machines");
        }
    }

    void Cancelar()
    {
        Navigation.NavigateTo("/machines");
    }
}