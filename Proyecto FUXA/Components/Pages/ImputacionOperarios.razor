@page "/imputacion-operarios"
@using Proyecto_FUXA.Models
@using Proyecto_FUXA.Services
@using Radzen
@using Radzen.Blazor

@inject NotificationService NotificationService


@inject ImputacionService ImputacionServicios

<h3>Imputacion Operarios</h3>

<div class="container-fluid">
    <div class="row">
        @* Columna de ancho fijo a la izquierda (aprox 40% de la pantalla) *@
        <div class="col-md-5 rz-p-4">

            <RadzenStack Gap="1.5rem">

                @* 1. Sección *@
                <RadzenStack Gap="0.4rem">
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color); font-weight: bold;">
                        1. CODIGO DE OPERACIÓN
                    </RadzenText>
                    <RadzenDropDown TValue="int"
                                    Data="@secciones"
                                    TextProperty="Nombre"
                                    ValueProperty="Id"
                                    Change="@OnSeccionChange"
                                    Style="width: 100%; max-width: 350px;"
                                    Placeholder="Seleccione..." />
                </RadzenStack>

                @* 2. Operario *@
                <RadzenStack Gap="0.4rem">
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color); font-weight: bold;">
                        2. TRABAJADOR
                    </RadzenText>
                    <RadzenDropDown TValue="int"
                                    Data="@empleados"
                                    @bind-Value="nuevaImputacion.IdEmpleado"
                                    ValueProperty="Id"
                                    AllowFiltering="true"
                                    Placeholder="Buscar nombre..."
                                    Style="width: 100%; max-width: 350px;">
                        <Template>
                            @((context as Empleado).Nombre)
                        </Template>
                    </RadzenDropDown>
                </RadzenStack>

                @* 3. Operación *@
                <RadzenStack Gap="0.4rem">
                    <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color); font-weight: bold;">
                        3. NUMERO DE HORAS
                    </RadzenText>
                    <RadzenDropDown TValue="int"
                                    Data="@operaciones"
                                    TextProperty="Nombre"
                                    ValueProperty="Id"
                                    @bind-Value="nuevaImputacion.IdOperacion"
                                    Placeholder="Seleccione tarea..."
                                    Style="width: 100%; max-width: 350px;" />
                </RadzenStack>

                @* Botón alineado al mismo ancho *@
                <div class="rz-mt-4">
                    <RadzenButton Click="@IniciarActividad"
                                  Text="INICIAR ACTIVIDAD"
                                  Icon="play_arrow"
                                  ButtonStyle="ButtonStyle.Success"
                                  Size="ButtonSize.Large"
                                  Style="width: 100%; max-width: 350px; font-weight: bold; height: 50px;" />
                </div>

            </RadzenStack>
        </div>

        @* Espacio vacío a la derecha para que el formulario se quede a la izquierda *@
        <div class="col-md-7"></div>
    </div>
</div>

@code {
    private List<Seccion> secciones = new();
    private List<Maquina> maquinas = new();
    private List<Empleado> empleados = new();
    private List<Operacion> operaciones = new();
    private List<Orden> maquinasOrdenes = new();
    private List<Orden> ordenesFiltradas = new();

    ImputacionOperario nuevaImputacion = new ImputacionOperario();

    int seccionSeleccionada;
    int maquinaSeleccionada;
    int empleadoSeleccionado;
    int operacionSeleccionada;

    protected override async Task OnInitializedAsync()
    {
        secciones = await ImputacionServicios.GetSeccionesAsync();
        operaciones = await ImputacionServicios.GetOperacionesAsync();
        empleados = await ImputacionServicios.GetEmpleadosAsync();
    }

    private async Task OnSeccionChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            seccionSeleccionada = id;
            maquinas = await ImputacionServicios.GetMaquinasBySeccionAsync(id);

            nuevaImputacion.IdMaquina = 0;
        }
    }
    private async Task OnSeccionChange(object value)
    {
        if (value is int idSeccion)
        {
            seccionSeleccionada = idSeccion;
            maquinas = await ImputacionServicios.GetMaquinasBySeccionAsync(idSeccion);

            maquinaSeleccionada = 0;
            nuevaImputacion.IdMaquina = 0;
        }
    }

    private async Task IniciarActividad()
    {
        if (nuevaImputacion.IdEmpleado == 0 || nuevaImputacion.IdMaquina == 0 || nuevaImputacion.IdOperacion == 0)
        {
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Warning, Summary = "Atención", Detail = "Faltan datos obligatorios", Duration = 4000 });
            return;
        }

        nuevaImputacion.FechaInicio = DateTime.Now;
        var resultado = await ImputacionServicios.GuardarImputacionAsync(nuevaImputacion);

        if (resultado)
        {
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Éxito", Detail = "Actividad iniciada correctamente", Duration = 4000 });
            nuevaImputacion = new ImputacionOperario();
            StateHasChanged();
        }
        else
        {
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Error", Detail = "No se pudo guardar en la base de datos", Duration = 4000 });
        }
    }
}
