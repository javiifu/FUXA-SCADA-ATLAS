@page "/ordenes"
@using Proyecto_FUXA.Models
@using Proyecto_FUXA.Services
@using Radzen
@using Radzen.Blazor
@inject ImputacionService ImputacionService
@inject DialogService DialogService
@inject NotificationService NotificationService

<div class="fuxa-enterprise-container">
    <RadzenStack Gap="1.5rem">

        @* CABECERA *@
        <RadzenRow AlignItems="AlignItems.Center">
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenStack Gap="0">
                    <RadzenText TextStyle="TextStyle.H4" TagName="TagName.H1" class="ent-title">
                        Gestión de Órdenes
                    </RadzenText>
                    <div class="ent-title-underline"></div>
                </RadzenStack>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End" Gap="1rem">
                    <RadzenButton Click="LimpiarBusqueda"
                                  Icon="filter_alt_off"
                                  Text="LIMPIAR FILTROS"
                                  ButtonStyle="ButtonStyle.Light"
                                  class="ent-btn-outline" />

                    <RadzenButton Click="@AbrirDialogoNuevaOrden"
                                  Text="NUEVA ORDEN"
                                  Icon="add_box"
                                  ButtonStyle="ButtonStyle.Primary"
                                  class="ent-btn-solid" />
                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>

        @* TABLA (GRID) *@
        <div class="ent-grid-wrapper">
            <RadzenDataGrid AllowFiltering="true" AllowPaging="true" PageSize="10" AllowSorting="true"
                            Data="@escaparateOrdenes" TItem="Orden" EmptyText="No hay órdenes creadas."
                            FilterMode="FilterMode.Simple" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                            class="ent-datagrid">
                <Columns>
                    <RadzenDataGridColumn TItem="Orden" Property="CodigoOrden" Title="CÓDIGO ORDEN" Width="160px">
                        <FilterTemplate>
                            <RadzenTextBox Placeholder="Buscar..."
                                           @bind-Value="filtroTexto"
                                           @oninput="@(args => { filtroTexto = args.Value.ToString(); AplicarFiltros(); })"
                                           class="ent-input w-100" />
                        </FilterTemplate>
                        <Template Context="o">
                            <strong>@o.CodigoOrden</strong>
                        </Template>
                    </RadzenDataGridColumn>
                        
                    <RadzenDataGridColumn TItem="Orden" Property="Producto" Title="PRODUCTO / DESCRIPCIÓN" />
                    
                    <RadzenDataGridColumn TItem="Orden" Property="FechaInicio" Title="FECHA INICIO" FormatString="{0:dd/MM/yyyy HH:mm}" Width="160px" />
                    
                    <RadzenDataGridColumn TItem="Orden" Property="FechaFin" Title="FECHA FIN" FormatString="{0:dd/MM/yyyy HH:mm}" Width="160px">
                        <Template Context="o">
                            @(o.FechaFin.HasValue ? o.FechaFin.Value.ToString("dd/MM/yyyy HH:mm") : "--")
                        </Template>
                    </RadzenDataGridColumn>
                    
                    <RadzenDataGridColumn TItem="Orden" Property="Estado" Title="ESTADO" Width="140px" TextAlign="TextAlign.Center">
                        <FilterTemplate>
                            <RadzenDropDown @bind-Value="filtroEstado"
                                            Data="@opcionesEstado"
                                            Change="@AplicarFiltros"
                                            class="ent-input w-100" />
                        </FilterTemplate>
                        <Template Context="o">
                            @* AQUÍ SE RESPETAN TUS COLORES ORIGINALES *@
                            <RadzenBadge BadgeStyle="@(o.Estado == "Activa" ? BadgeStyle.Success :
                                                                                                                            o.Estado == "Finalizado" ? BadgeStyle.Danger :
                                                                                                                            BadgeStyle.Info)"
                                         Text="@o.Estado.ToUpper()"
                                         class="ent-badge" />
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="Orden" Title="ACCIONES" Width="100px" TextAlign="TextAlign.Center" Filterable="false" Sortable="false">
                        <Template Context="o">
                            <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Text" Size="ButtonSize.Medium"
                                          Click="@(args => EditarOrden(o))" class="ent-action-btn" />
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </div>
    </RadzenStack>
</div>

<style>
    /* Fondo general */
    .fuxa-enterprise-container {
        background-color: #FAFAFA;
        min-height: 100vh;
        padding: 2rem;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    /* Títulos */
    .ent-title {
        color: #1A2E3F;
        font-weight: 800 !important;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin: 0;
    }

    .ent-title-underline {
        height: 4px;
        width: 60px;
        background-color: #1F4E79;
        margin-top: 5px;
    }

    /* Contenedor de la tabla con borde estricto */
    .ent-grid-wrapper {
        border: 1px solid #D5E3EF;
        background: white;
        border-radius: 4px;
        overflow: hidden;
    }

    /* ---- ESTILOS DE LA TABLA (DATAGRID) ---- */
    .ent-datagrid {
        border: none !important;
    }

    /* Cabecera oscura corporativa */
    .ent-datagrid .rz-datagrid-header-cell {
        background-color: #1A2E3F !important;
        color: #FFFFFF !important;
        font-weight: 600 !important;
        font-size: 0.85rem !important;
        letter-spacing: 0.5px;
        border-bottom: 3px solid #1F4E79 !important;
        padding: 12px 15px !important;
        text-transform: uppercase;
    }

    /* Iconos de ordenación en la cabecera */
    .ent-datagrid .rz-datagrid-header-cell .rz-sortable-column-icon {
        color: #7BB3D4 !important;
    }

    /* Filas de la tabla */
    .ent-datagrid .rz-datagrid-row td {
        border-bottom: 1px solid #EEEEEE !important;
        padding: 12px 15px !important;
        color: #333333 !important;
        font-size: 0.95rem;
    }

    /* Filas alternas (Zebra stripes) para leer mejor los datos */
    .ent-datagrid .rz-datagrid-row:nth-child(even) > td {
        background-color: #F8F9FA !important;
    }

    /* Efecto hover al pasar el ratón */
    .ent-datagrid .rz-datagrid-row:hover td {
        background-color: #E6F2FF !important;
    }

    /* ---- ETIQUETAS Y BOTONES ---- */
    .ent-badge {
        border-radius: 4px !important;
        padding: 6px 12px !important;
        font-weight: bold !important;
        letter-spacing: 0.5px;
        font-size: 0.8rem;
    }

    .ent-input {
        border-radius: 4px !important;
        border: 1px solid #CCCCCC !important;
    }

    .ent-input:focus {
        border-color: #1F4E79 !important;
        box-shadow: 0 0 0 2px rgba(31,78,121,0.2) !important;
    }

    /* Botones superiores */
    .ent-btn-solid {
        background-color: #1F4E79 !important;
        border-radius: 4px !important;
        font-weight: 600 !important;
        box-shadow: none !important;
    }

    .ent-btn-solid:hover {
        background-color: #163857 !important;
    }

    .ent-btn-outline {
        border: 1px solid #1F4E79 !important;
        color: #1F4E79 !important;
        border-radius: 4px !important;
        font-weight: 600 !important;
        background-color: transparent !important;
    }

    .ent-btn-outline:hover {
        background-color: #F0F4F8 !important;
    }

    /* Botón de editar de la tabla */
    .ent-action-btn {
        color: #1F4E79 !important;
        background: transparent !important;
    }

    .ent-action-btn:hover {
        background: #E6F2FF !important;
    }
</style>

@code {
    List<Orden> listaOrdenes = new();
    List<Orden> almacenOrdenes = new();
    List<Orden> escaparateOrdenes = new();

    string filtroTexto = "";
    string filtroEstado = "TODOS";
    List<string> opcionesEstado = new List<string> { "TODOS", "Activa", "Finalizado", "Pendiente" };

    protected override async Task OnInitializedAsync()
    {
        await CargarOrdenes();
    }

    private async Task CargarOrdenes()
    {
        var datos = await ImputacionService.ObtenerOrdenesAsync();
        almacenOrdenes = datos.ToList();
        AplicarFiltros();
    }

    private async Task AbrirDialogoNuevaOrden()
    {
        var res = await DialogService.OpenAsync<DialogoPlanificarOrden>("Planificar nueva orden",
            new Dictionary<string, object>(),
            new DialogOptions() { Width = "500px", Style = "position: absolute;" });

        if (res == true)
        {
            await CargarOrdenes();
        }
    }

    private async Task EditarOrden(Orden orden)
    {
        var parametros = new Dictionary<string, object> {
            { "OrdenParaEditar", orden }
        };

        var res = await DialogService.OpenAsync<DialogoPlanificarOrden>("Editar orden", parametros, new DialogOptions() { Width = "500px" });

        if (res == true)
        {
            await CargarOrdenes();
        }
    }

    private void LimpiarBusqueda()
    {
        filtroTexto = "";
        filtroEstado = "TODOS";
        AplicarFiltros();
    }

    private void AplicarFiltros()
    {
        var resultadoTemporal = almacenOrdenes.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(filtroTexto))
        {
            resultadoTemporal = resultadoTemporal.Where(orden => orden.CodigoOrden != null && orden.CodigoOrden.Contains(filtroTexto, StringComparison.OrdinalIgnoreCase));
        }
        if (filtroEstado != "TODOS")
        {
            resultadoTemporal = resultadoTemporal.Where(orden => orden.Estado == filtroEstado);
        }
        resultadoTemporal = resultadoTemporal.OrderBy(orden => orden.Estado switch
        {
            "Activa" => 1,
            "Pendiente" => 2,
            "Finalizado" => 3,
            _ => 4
        })
        .ThenByDescending(orden => orden.FechaInicio);
        escaparateOrdenes = resultadoTemporal.ToList();
    }
}