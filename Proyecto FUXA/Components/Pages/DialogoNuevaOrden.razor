@page "/dialogo-nueva-orden"
@using Proyecto_FUXA.Models
@using Proyecto_FUXA.Services
@using Radzen
@using Radzen.Blazor
@inject Radzen.DialogService DialogService
@inject Proyecto_FUXA.Services.ImputacionService ImputacionService
@inject NotificationService NotificationService


<RadzenTemplateForm TItem="MaquinasOrdenes" Data="@nuevaOrden" Submit="@GuardarOrden">
    <div class="container-fluid">
        
        <div class="row p-2 bg-light border-bottom rz-mb-4">
            <div class="col-md-6">
                <RadzenText TextStyle="TextStyle.Caption">Sección</RadzenText>
                <RadzenTextBox Value="@MaquinaCreacion.NombreSeccion" Style="width: 100%;" Disabled="true" />
            </div>
            <div class="col-md-6">
                <RadzenText TextStyle="TextStyle.Caption">Máquina</RadzenText>
                <RadzenTextBox Value="@MaquinaCreacion.Nombre" Style="width: 100%;" Disabled="true" />
            </div>
        </div>

        <div class="row p-2">
            <div class="col-md-6">
                <RadzenText TextStyle="TextStyle.Subtitle2">Código de Orden (OT)</RadzenText>
                <RadzenTextBox @bind-Value="nuevaOrden.CodigoOrden" Style="width: 100%;" Name="CodigoOrden" />
                <RadzenRequiredValidator Component="CodigoOrden" Text="El código es obligatorio" Popup="true" />
            </div>
            <div class="col-md-6">
                <RadzenText TextStyle="TextStyle.Subtitle2">Producto</RadzenText>
                <RadzenTextBox @bind-Value="nuevaOrden.Producto" Style="width: 100%;" />
            </div>
        </div>

        <div class="row p-2">
            <div class="col-md-4">
                <RadzenText TextStyle="TextStyle.Subtitle2">Ciclos Objetivo</RadzenText>
                <RadzenNumeric @bind-Value="nuevaOrden.CiclosObjetivo" Style="width: 100%;" />
            </div>
            <div class="col-md-4">
                <RadzenText TextStyle="TextStyle.Subtitle2">Estado</RadzenText>
                <RadzenTextBox @bind-Value="nuevaOrden.Estado" Style="width: 100%;" Placeholder="Ej: Planificada" />
            </div>
             <div class="col-md-4">
                <RadzenText TextStyle="TextStyle.Subtitle2">Creado Por (Empleado ID)</RadzenText>
                <RadzenNumeric @bind-Value="nuevaOrden.EmpleadoId" Style="width: 100%;" Placeholder="Opcional" />
                <RadzenText TextStyle="TextStyle.Caption">ID del administrativo/jefe que la crea.</RadzenText>
            </div>
        </div>

        <div class="row p-2">
            <div class="col-md-6">
                <RadzenText TextStyle="TextStyle.Subtitle2">Fecha Inicio Prevista</RadzenText>
                <RadzenDatePicker @bind-Value="nuevaOrden.FechaInicio" Style="width: 100%;" ShowTime="true" DateFormat="dd/MM/yyyy HH:mm" />
            </div>
            <div class="col-md-6">
                <RadzenText TextStyle="TextStyle.Subtitle2">Fecha Fin Prevista</RadzenText>
                <RadzenDatePicker @bind-Value="nuevaOrden.FechaFin" Style="width: 100%;" ShowTime="true" DateFormat="dd/MM/yyyy HH:mm" AllowClear="true" />
            </div>
        </div>

        <div class="row p-3 text-right">
            <div class="col-md-12">
                <RadzenButton Text="Cancelar" Click="@((args) => DialogService.Close(false))" ButtonStyle="ButtonStyle.Light" Class="rz-mr-2" />
                <RadzenButton Text="Crear Orden" ButtonType="ButtonType.Submit" ButtonStyle="ButtonStyle.Primary" Icon="save" />
            </div>
        </div>
    </div>
</RadzenTemplateForm>

@code {
    // Parámetro que recibimos de la pantalla principal
    [Parameter] public Maquina MaquinaCreacion { get; set; }

    private MaquinasOrdenes nuevaOrden = new MaquinasOrdenes();

    protected override void OnInitialized()
    {
        nuevaOrden.IdMaquina = MaquinaCreacion.Id;
        nuevaOrden.FechaInicio = DateTime.Now;
        nuevaOrden.Estado = "Planificada";
    }

    private async Task GuardarOrden()
    {
        // intentamos guardar usando el servicio que creamos antes
        var resultado = await ImputacionService.CrearNuevaOrdenAsync(nuevaOrden);

        if (resultado)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary = "¡Éxito!",
                Detail = "La orden se ha creado correctamente",
                Duration = 4000
            });

            DialogService.Close(true);
        }
        else
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Error",
                Detail = "No se pudo guardar la orden. Revisa los datos.",
                Duration = 4000
            });
        }
    }
}