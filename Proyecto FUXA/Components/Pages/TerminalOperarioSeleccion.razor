@page "/terminal-operario-seleccion"
@using Proyecto_FUXA.Models
@using Proyecto_FUXA.Services
@using Radzen
@using Radzen.Blazor
@inject ServicioMaquina ServicioMaquina
@inject ImputacionService ImputacionService
@inject NavigationManager NavManager

<RadzenStack Gap="1.5rem" class="rz-p-6">
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
            @if (seccionSeleccionada != null)
            {
                <RadzenButton Icon="arrow_back" Click="VolverASecciones" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat" Size="ButtonSize.Large" />
            }
            <RadzenText TextStyle="TextStyle.H4" Style="margin: 0;">
                @(seccionSeleccionada == null ? "Seleccione Sección" : $"Máquinas en {seccionSeleccionada.Nombre}")
            </RadzenText>
        </RadzenStack>

        @if (seccionSeleccionada != null)
        {
            <RadzenBadge BadgeStyle="BadgeStyle.Info" Text="@($"Prioridad: {seccionSeleccionada.Preferencia}")" Style="font-size: 1.1rem; padding: 10px;" />
        }
    </RadzenStack>

    @if (listaSecciones == null)
    {
        <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
    }
    else
    {
        @* PASO 1: Listar Secciones *@
        @if (seccionSeleccionada == null)
        {
            <RadzenDataList Data="@listaSecciones" TItem="Seccion" WrapItems="true">
                <Template Context="s">
                    <RadzenCard @onclick="@(() => SeleccionarSeccion(s))"
                                class="rz-m-2 rz-shadow-6 selection-card section-style">
                        <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Gap="1rem">
                            <RadzenIcon Icon="account_tree" Style="font-size: 4rem; color: #1F4E79;" />
                            <RadzenText TextStyle="TextStyle.H5" Style="font-weight: bold; color: #1A2E3F;">@s.Nombre</RadzenText>
                            <RadzenBadge BadgeStyle="BadgeStyle.Secondary" Text="@($"Preferencia: {s.Preferencia}")" />
                        </RadzenStack>
                    </RadzenCard>
                </Template>
            </RadzenDataList>
        }
        @* PASO 2: Listar Máquinas de la sección *@
        else
        {
            @if (listaMaquinasFiltradas == null || !listaMaquinasFiltradas.Any())
            {
                <RadzenAlert AlertStyle="AlertStyle.Warning" Text="No hay máquinas registradas en esta sección." AllowClose="false" />
            }
            else
            {
                <RadzenDataList Data="@listaMaquinasFiltradas" TItem="Maquina" WrapItems="true">
                    <Template Context="m">
                        <RadzenCard @onclick="@(() => IrATerminal(m.Id))"
                                    class="rz-m-2 rz-shadow-6 selection-card machine-style">
                            <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Gap="1rem">
                                <RadzenIcon Icon="settings_suggest" Style="font-size: 4rem; color: #28a745;" />
                                <RadzenText TextStyle="TextStyle.H5" Style="font-weight: bold; color: #1A2E3F;">@m.Nombre</RadzenText>
                                <RadzenText TextStyle="TextStyle.Caption">ID Máquina: @m.Id</RadzenText>
                            </RadzenStack>
                        </RadzenCard>
                    </Template>
                </RadzenDataList>
            }
        }
    }
</RadzenStack>

<style>
    .selection-card {
        width: 280px;
        height: 200px;
        cursor: pointer;
        transition: all 0.2s ease-in-out;
        border-radius: 16px !important;
        border: 2px solid transparent;
    }

    .section-style:hover {
        transform: translateY(-5px);
        border-color: #1F4E79 !important;
        background-color: #f0f4f8;
    }

    .machine-style:hover {
        transform: translateY(-5px);
        border-color: #28a745 !important;
        background-color: #f0fdf4;
    }
</style>

@code {
    private List<Seccion> listaSecciones;
    private List<Maquina> listaMaquinasFiltradas;
    private Seccion seccionSeleccionada = null;

    protected override async Task OnInitializedAsync()
    {
        listaSecciones = await ImputacionService.GetSeccionesAsync();
    }

    private async Task SeleccionarSeccion(Seccion seccion)
    {
        seccionSeleccionada = seccion;
        listaMaquinasFiltradas = await ImputacionService.GetMaquinasBySeccionAsync(seccion.Id);
    }

    private void VolverASecciones()
    {
        seccionSeleccionada = null;
        listaMaquinasFiltradas = null;
    }

    private void IrATerminal(int id)
    {
        NavManager.NavigateTo($"/terminal-operario/{id}");
    }
}