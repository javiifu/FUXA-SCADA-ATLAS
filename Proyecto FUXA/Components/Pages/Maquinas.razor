@page "/maquinas"

@using Proyecto_FUXA.Models
@inject Proyecto_FUXA.Services.ServicioMaquina ServicioMaquina

<h1>Maquinas</h1>

<a class="btn btn-lg btn-primary float-lg-end" href="/anadir-maquina/">+ Añadir maquina</a>

@if (!string.IsNullOrWhiteSpace(errorCarga))
{
    <div class="alert alert-danger mt-3">
        <strong>No se pudieron cargar las máquinas.</strong>
        <div>@errorCarga</div>
    </div>
}
else if (maquinas is null)
{
    <text>Cargando...</text>
}
else
{
    <table class="table table-striped">

        <thread>
            <tr>
                
                <th>
                    ID Técnico
                </th>
                <th>Nombre Máquina</th>
                <th>Tipo Máquina</th>
                <th>Estado</th>
            </tr>
        </thread>
        <tbody>
            @foreach (var maquina in maquinas)
            {
                <tr>
                    <!--<td>@Index</td>-->
                    <td><code class="text-muted">@maquina.FuxaDeviceId</code></td>
                    <td><code class="text-muted">@maquina.Nombre</code></td>
                    <td><code class="text-muted">@maquina.NombreSeccion</code></td>
                    <td>
                        @if (maquina.EstaActivo)
                        {
                            <span class="badge bg-success">Activa</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactiva</span>
                        }
                    </td>
                </tr>
            }
        </tbody>

    </table>
    
}

@code {
    private List<Maquina>? maquinas;
    private string? errorCarga;


    protected override async Task OnInitializedAsync()
    {
        try
        {
            maquinas = await ServicioMaquina.GetAllAsync();
        }
        catch (Exception ex)
        {
            errorCarga = ex.Message;
            maquinas = new List<Maquina>();
        }
    }
}
