@page "/planta"
@using Proyecto_FUXA.Models
@using Proyecto_FUXA.Services

@inject ServicioPlantaVisual ServicioPlantaVisual
@inject ServicioProductividad ProductivityService

<h3>Planta</h3>

<div class="d-flex justify-content-end mb-2">
    <a class="btn btn-outline-primary btn-sm" href="/planta-editor">Editar layout</a>
</div>

@if (objetos.Count == 0)
{
    <p class="text-muted">No hay elementos en el layout. Usa el editor para añadir rectángulos.</p>
}
else
{
    <div class="planta-visor-canvas">
        @foreach (var objeto in objetos)
        {
            var productividad = GetProductivity(objeto.Maquina);
            var colorFondo = GetColor(productividad, objeto.ColorHex);

            <div class="planta-visor-objeto"
                 style="@BuildObjectStyle(objeto, colorFondo)">
                <div class="planta-visor-nombre">@objeto.Nombre</div>

                @if (objeto.Maquina is null)
                {
                    <div class="planta-visor-detalle">Sin máquina vinculada</div>
                }
                else
                {
                    <div class="planta-visor-detalle">@objeto.Maquina.Nombre</div>
                    <div class="planta-visor-detalle">Prod: @productividad%</div>
                }
            </div>
        }
    </div>
}

@code {
    private List<PlantaObjetoVisual> objetos = new();

    protected override async Task OnInitializedAsync()
    {
        objetos = await ServicioPlantaVisual.GetAllAsync();
    }

    private int GetProductivity(Maquina? machine)
    {
        if (machine is null)
        {
            return 0;
        }

        var last = machine.Producciones?
            .OrderByDescending(p => p.FechaRegistro)
            .FirstOrDefault();

        var realCycles = last?.CiclosReales ?? 0;

        return Convert.ToInt32(ProductivityService.Calcular(realCycles, machine.CiclosObjetivo));
    }

    private static string GetColor(int productivity, string fallbackColor)
    {
        if (productivity >= 70) return "#2e7d32";
        if (productivity >= 30) return "#f9a825";
        if (productivity > 0) return "#c62828";

        return string.IsNullOrWhiteSpace(fallbackColor)
            ? "#2f80ed"
            : (fallbackColor.StartsWith('#') ? fallbackColor : $"#{fallbackColor}");
    }

    private static string BuildObjectStyle(PlantaObjetoVisual objeto, string color)
    {
        return $"left:{objeto.PosX}px;top:{objeto.PosY}px;width:{Math.Max(20, objeto.Width)}px;height:{Math.Max(20, objeto.Height)}px;background:{color};";
    }
}
