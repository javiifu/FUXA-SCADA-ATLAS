        }

    .pcs-card-fuxa {
        background: white;
        border: 1px solid #D5E3EF;
        padding: 20px;
        border-radius: 12px;
        text-align: center;
    }

    .rz-numeric input {
        font-size: inherit !important;
        height: auto !important;
        background: transparent !important;
    }

        .rz-numeric input:focus {
            outline: none !important;
            box-shadow: none !important;
        }

    .order-card-modern {
        background: #ffffff;
