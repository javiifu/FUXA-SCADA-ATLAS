</style>

@code {
    [Parameter] public int IdMaquina { get; set; }

    private Maquina maquinaActual;

    // Lista con todos los empleados de la base de datos
    private List<Empleado> listaEmpleados;
    private List<OperacionResumenDTO> ordenesDisponibles;

    private string currentTime = DateTime.Now.ToString("HH:mm:ss");
    private int pasoActual = 1;
    private Timer timer;

    private Empleado operarioSeleccionado;
    private string ordenPadreSeleccionada;
    private OperacionResumenDTO ordenSeleccionada;

    private int segundosTrabajo = 0;
    private bool estaPausado = false;
    private string tipoActividad = "Produccion";
    private int piezasFabricadas = 0;
    private int piezasRotas = 0;
    private int ciclosReales = 0;
    private DateTime horaInicioProceso;
    private bool isDisposed = false;
    private bool dialogoAbierto = false;
    private int? preferenciaActual;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            maquinaActual = await ServicioMaquina.GetByIdAsync(IdMaquina);
            preferenciaActual = await ServicioMaquina.PreferenciaPorMaquinaId(IdMaquina);

            // Cargamos todos los empleados de la BD para el Paso 1
            listaEmpleados = await ImputacionService.GetEmpleadosAsync();

            await CargarDatos();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando datos: {ex.Message}");
            listaEmpleados = new List<Empleado>();
        }

        timer = new Timer(1000);
        timer.Elapsed += OnTimerElapsed;
        timer.AutoReset = true;
        timer.Enabled = true;
    }

    private async void OnTimerElapsed(object sender, ElapsedEventArgs e)
    {
        if (isDisposed) return;

        currentTime = DateTime.Now.ToString("HH:mm:ss");

        if (pasoActual == 4 && !estaPausado)
        {
            segundosTrabajo++;
        }

        if (dialogoAbierto) return;
        try
        {
            await InvokeAsync(StateHasChanged);
        }
        catch { }
    }

    // PASO 1 -> PASO 2
    private void SeleccionarOperario(Empleado emp)
    {
        operarioSeleccionado = emp;
        pasoActual = 2;
    }

    // PASO 2 -> PASO 3
    private void SeleccionarOrdenPadre(string codigoOrden)
    {
        ordenPadreSeleccionada = codigoOrden;
        pasoActual = 3;
    }

    // PASO 3 -> PASO 4 (VALIDACIÓN FINAL)
    private async Task SeleccionarOperacion(OperacionResumenDTO orden)
    {
        var ordenPadre = await ImputacionService.GetOrdenById(orden.NombreOrden);
        if (ordenPadre == null) return;

        bool puedeEmpezar = await ImputacionService.PuedeIniciarOperacionAsync(orden.Id, ordenPadre.Id);

        if (!puedeEmpezar)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "BLOQUEO DE PROCESO",
                Detail = "No puedes iniciar la operacion. Hay procesos anteriores pendientes.",
                Duration = 5000
            });
            return;
        }

        ordenSeleccionada = orden;
        piezasFabricadas = 0;
        piezasRotas = 0;
        ciclosReales = 0;
        estaPausado = false;
        horaInicioProceso = DateTime.Now;

        if (orden.Estado == "Pendiente")
        {
            await ImputacionService.IniciarFichajeAsync(orden.Id, operarioSeleccionado.Id);
        }

        pasoActual = 4;
        StateHasChanged();
    }

    private void ModificarPiezasFabricadas(int valor) => piezasFabricadas = Math.Max(0, piezasFabricadas + valor);
    private void ModificarPiezasRotas(int valor) => piezasRotas = Math.Max(0, piezasRotas + valor);
    private void PausarImputacion() => estaPausado = !estaPausado;

    private async Task FinalizarImputacion()
    {
        bool operacionCerrada = await ImputacionService.VerificarOperacionCerrada(ordenSeleccionada.Id);
        decimal horas = (decimal)segundosTrabajo / 3600;

        bool exito = await ImputacionService.ImputarTrabajoDesdeTerminalAsync(
            ordenSeleccionada.Id, IdMaquina, operarioSeleccionado.Id,
            horaInicioProceso, DateTime.Now, piezasFabricadas, piezasRotas
        );

        if (exito)
        {
            if (operacionCerrada)
            {
                NotificationService.Notify(NotificationSeverity.Warning, "Aviso", "Turno guardado. (Nota: La operación ya había sido finalizada por otro compañero).", duration: 5000);
            }
            else
            {
                NotificationService.Notify(NotificationSeverity.Success, "Éxito", "Turno guardado correctamente.");
            }

            isDisposed = true;
            if (timer != null) timer.Stop();
            await Task.Delay(1000);
            NavManager.NavigateTo("/terminal-operario-seleccion");
        }
    }

    private async Task CerrarOperacion()
    {
        dialogoAbierto = true;

        var confirmacion = await DialogService.OpenAsync<DialogoFinalizarOperacion>("",
            new Dictionary<string, object>
            {
                { "OperacionActiva", ordenSeleccionada },
                { "PiezasFabricadas", piezasFabricadas },
                { "PiezasRotas", piezasRotas }
            },
            new DialogOptions() { Width = "550px", ShowTitle = false, ShowClose = false, Style = "border-radius: 16px; padding: 0;" }
        );

        dialogoAbierto = false;
        if (isDisposed) return;

        if (confirmacion == true)
        {
            bool operacionCerrada = await ImputacionService.VerificarOperacionCerrada(ordenSeleccionada.Id);

            if (piezasFabricadas > 0 || piezasRotas > 0 || ciclosReales > 0)
            {
                await ImputacionService.ImputarTrabajoDesdeTerminalAsync(
                    ordenSeleccionada.Id, IdMaquina, operarioSeleccionado.Id,
                    horaInicioProceso, DateTime.Now, piezasFabricadas, piezasRotas
                );
            }

            if (operacionCerrada)
            {
                NotificationService.Notify(NotificationSeverity.Warning, "Información", "Tus piezas se han guardado, pero la operación ya había sido finalizada.", duration: 5000);
            }
            else
            {
                await ImputacionService.CerrarOperacionAsync(ordenSeleccionada.Id);
                NotificationService.Notify(NotificationSeverity.Success, "Completado", "Operación cerrada y piezas guardadas.");
            }

            isDisposed = true;
            if (timer != null) timer.Stop();
            await Task.Delay(1500);
            NavManager.NavigateTo("/terminal-operario-seleccion");
        }
    }

    private async Task AbrirDialogoMateriales()
    {
        dialogoAbierto = true;
        await DialogService.OpenAsync<DialogoMaterialesOperacion>(
            $"Materiales - {maquinaActual.Nombre}",
            new Dictionary<string, object>
            {
                { "IdMaquina", IdMaquina },
                { "IdOperacion", ordenSeleccionada.Id },
                { "IdEmpleado", operarioSeleccionado.Id}
            },
            new DialogOptions() { Width = "1200px", Resizable = false, Draggable = true, Style = "border-radius: 16px;" }
        );
        dialogoAbierto = false;
    }

    private async Task AbrirDialogoNuevaOrden()
    {
        dialogoAbierto = true;
        var resultado = await DialogService.OpenAsync<DialogoNuevaOperacionOperario>($"Nueva Operación - {maquinaActual?.Nombre}",
            new Dictionary<string, object> { { "IdMaquina", IdMaquina } },
            new DialogOptions() { Width = "500px", Resizable = true, Draggable = true });

        dialogoAbierto = false;
        if (isDisposed) return;

        if (resultado == true)
        {
            await CargarDatos();
        }
    }

    private async Task CargarDatos()
    {
        ordenesDisponibles = await ImputacionService.ObtenerOperacionesActivasAsync();
        ordenesDisponibles = ordenesDisponibles.Where(o => o.IdMaquina == IdMaquina).ToList();
        StateHasChanged();
    }

    public void Dispose()
    {
        isDisposed = true;
        if (timer != null)
        {
            timer.Stop();
            timer.Dispose();
            timer = null;
        }
    }
}