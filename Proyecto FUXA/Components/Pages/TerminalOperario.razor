@page "/terminal-operario/{IdMaquina:int}"
@using Proyecto_FUXA.Models
@using Proyecto_FUXA.Services
@using System.Timers
@using Radzen
@using Radzen.Blazor
@using static Proyecto_FUXA.Services.ImputacionService
@implements IDisposable

@inject ServicioMaquina ServicioMaquina
@inject NavigationManager NavManager
@inject ImputacionService ImputacionService
@inject NotificationService NotificationService
@inject DialogService DialogService

<div class="terminal-container">
    <div class="topbar">
        <div class="topbar-left">
            <div class="machine-id">MÁQUINA @IdMaquina</div>
            <div class="machine-name">
                @(maquinaActual?.Nombre ?? "Cargando...")
                <span style="font-size: 0.9rem; color: #7BB3D4; margin-left: 10px;">
                    (Prioridad: @(preferenciaActual?.ToString() ?? "--"))
                </span>
            </div>
        </div>
        <div class="topbar-center">
            <div class="clock-big">@currentTime</div>
        </div>
        <div class="topbar-right">
            <RadzenButton Click="@(() => NavManager.NavigateTo("/terminal-operario-seleccion"))"
                          Icon="arrow_back" Text="VOLVER AL MENÚ" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" />
        </div>
    </div>

    <div class="step-content">

        @* PASO 1: SELECCIONAR OPERARIO *@
        @if (pasoActual == 1)
        {
            <RadzenText TextStyle="TextStyle.H5" class="instruction">Paso 1: Seleccione Operario</RadzenText>

            @if (listaEmpleados == null)
            {
                <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
            }
            else if (!listaEmpleados.Any())
            {
                <RadzenAlert AlertStyle="AlertStyle.Warning" Variant="Variant.Flat" Shade="Shade.Lighter" AllowClose="false">
                    No hay operarios en la base de datos.
                </RadzenAlert>
            }
            else
            {
                <div class="operario-grid">
                    @foreach (var op in listaEmpleados)
                    {
                        <div class="operario-card" @onclick="() => SeleccionarOperario(op)">
                            <div class="avatar">@(string.IsNullOrEmpty(op.Nombre) ? "?" : op.Nombre.Substring(0, 1))</div>
                            <div class="name">@op.Nombre</div>
                            <div class="surname">@op.Apellidos</div>
                            <div style="font-size:0.8rem; color:#8AAEC8; margin-top:5px;">@(op.CodigoEmpleado ?? "Sin código")</div>
                        </div>
                    }
                </div>
            }
        }

        @* PASO 2: SELECCIONAR ORDEN PADRE *@
        else if (pasoActual == 2)
        {
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" class="rz-mb-4">
                <RadzenButton Icon="arrow_back" Click="() => pasoActual = 1" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat" Size="ButtonSize.Medium" />
                <RadzenText TextStyle="TextStyle.H5" class="instruction" Style="margin: 0 0 0 10px; border: none;">
                    Paso 2: Seleccione Orden de Fabricación
                </RadzenText>
            </RadzenStack>

            @if (!ordenesDisponibles.Any())
            {
                <RadzenAlert AlertStyle="AlertStyle.Warning" Variant="Variant.Flat" Shade="Shade.Lighter" AllowClose="false">
                    No hay órdenes activas para esta máquina.
                </RadzenAlert>
            }
            else
            {
                <RadzenStack Gap="1.2rem" class="rz-p-2">
                    @foreach (var grupo in ordenesDisponibles.GroupBy(o => new { o.NombreOrden, o.Producto }))
                    {
                        <RadzenCard @onclick="() => SeleccionarOrdenPadre(grupo.Key.NombreOrden)" class="order-card-modern" Style="border-left: 8px solid #1F4E79;">
                            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
                                <RadzenStack Gap="0.5rem">
                                    <RadzenText TextStyle="TextStyle.H5" Style="margin:0; font-weight: 800; color:#1A2E3F; letter-spacing: 0.5px;">
                                        @grupo.Key.NombreOrden
                                    </RadzenText>
                                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                        <RadzenIcon Icon="inventory_2" Style="font-size: 1.1rem; color: #6B8FAD;" />
                                        <RadzenText TextStyle="TextStyle.Body1" Style="color: #4A5568; font-weight: 500;">
                                            @grupo.Key.Producto
                                        </RadzenText>
                                    </RadzenStack>
                                    <RadzenBadge BadgeStyle="BadgeStyle.Info" IsPill="true" Text="@($"{grupo.Count()} tareas disponibles")" Style="width: fit-content; padding: 5px 12px;" />
                                </RadzenStack>
                                <RadzenIcon Icon="chevron_right" Style="font-size: 3rem; color: #cbd5e0;" />
                            </RadzenStack>
                        </RadzenCard>
                    }
                </RadzenStack>
            }

            <div style="margin-top: 3rem;">
                <RadzenButton Text="CREAR NUEVA OPERACIÓN"
                              Icon="add_circle"
                              ButtonStyle="ButtonStyle.Success"
                              Size="ButtonSize.Large"
                              Click="AbrirDialogoNuevaOrden"
                              Style="height: 70px; font-weight: bold; border-radius: 12px; width: 100%; font-size: 1.2rem;" />
            </div>
        }

        @* PASO 3: SELECCIONAR OPERACIÓN (TAREA) *@
        else if (pasoActual == 3)
        {
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" class="rz-mb-4">
                <RadzenButton Icon="arrow_back" Click="() => pasoActual = 2" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat" Size="ButtonSize.Medium" />
                <RadzenText TextStyle="TextStyle.H5" class="instruction" Style="margin: 0 0 0 10px; border: none;">
                    Paso 3: Seleccione tarea para @ordenPadreSeleccionada
                </RadzenText>
            </RadzenStack>

            <RadzenStack Gap="1.2rem" class="rz-p-2">
                @foreach (var orden in ordenesDisponibles.Where(o => o.NombreOrden == ordenPadreSeleccionada))
                {
                    <RadzenCard @onclick="() => SeleccionarOperacion(orden)"
                                class="order-card-modern"
                                Style="@(orden.Estado == "Activa" ? "border-left: 8px solid #28a745;" : "border-left: 8px solid #17a2b8;")">

                        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
                            <RadzenStack Gap="0.5rem">
                                <RadzenText TextStyle="TextStyle.H5" Style="margin:0; font-weight: 800; color:#1A2E3F; letter-spacing: 0.5px;">
                                    @orden.CodigoOperacion
                                </RadzenText>
                                <RadzenBadge BadgeStyle="BadgeStyle.Light" IsPill="true" Text="@($"Objetivo: {orden.CiclosObjetivo} pcs")" Style="width: fit-content; padding: 5px 12px;" />
                            </RadzenStack>

                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="2rem">
                                <div class="status-badge-container">
                                    @if (orden.Estado.Equals("Activa"))
                                    {
                                        <RadzenBadge BadgeStyle="BadgeStyle.Success" class="badge-xl" Text="ACTIVA" />
                                    }
                                    else if (orden.Estado.Equals("Pendiente"))
                                    {
                                        <RadzenBadge BadgeStyle="BadgeStyle.Info" class="badge-xl" Text="PENDIENTE" />
                                    }
                                </div>
                                <RadzenIcon Icon="@(orden.Estado == "Activa" ? "play_circle" : "pause_circle")"
                                            Style="@($"font-size: 3.5rem; color: {(orden.Estado == "Activa" ? "#28a745" : "#cbd5e0")};")" />
                            </RadzenStack>
                        </RadzenStack>
                    </RadzenCard>
                }
            </RadzenStack>
        }

        @* PASO 4: PANEL DE CONTROL *@
        else if (pasoActual == 4)
        {
            <RadzenStack Gap="1.5rem">
                <RadzenCard Variant="Variant.Flat" Style="background: #fff; border: 1px solid #D5E3EF;" class="rz-mb-4">
                    <RadzenRow AlignItems="AlignItems.Center">
                        <RadzenColumn Size="12" SizeMD="4">
                            <RadzenStack Gap="0">
                                <RadzenText TextStyle="TextStyle.Overline" Style="color: #6B8FAD;">IDENTIFICACIÓN</RadzenText>
                                <RadzenText TextStyle="TextStyle.Body1"><b>Operacion:</b> @ordenSeleccionada.CodigoOperacion</RadzenText>
                                <RadzenText TextStyle="TextStyle.Body1"><b>Operario:</b> @operarioSeleccionado.Nombre @operarioSeleccionado.Apellidos</RadzenText>
                            </RadzenStack>
                        </RadzenColumn>

                        <RadzenColumn Size="12" SizeMD="8">
                            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="2rem">
                                <RadzenStack Gap="0" Style="text-align: center;">
                                    <RadzenText TextStyle="TextStyle.Overline" Style="color: #6B8FAD;">CICLOS OBJETIVO</RadzenText>
                                    <RadzenText TextStyle="TextStyle.H6"><b>@ordenSeleccionada.CiclosObjetivo</b></RadzenText>
                                </RadzenStack>

                                <RadzenStack Gap="0" Style="text-align: center; border-left: 1px solid #D5E3EF; padding-left: 2rem;">
                                    <RadzenText TextStyle="TextStyle.Overline" Style="color: #6B8FAD;">PIEZAS FABRICADAS</RadzenText>
                                    <RadzenText TextStyle="TextStyle.H6" Style="color: var(--rz-primary);">
                                        <b>@ordenSeleccionada.PiezasFabricadas</b>
                                    </RadzenText>
                                </RadzenStack>

                                <RadzenStack Gap="0" Style="text-align: center; border-left: 1px solid #D5E3EF; padding-left: 2rem;">
                                    <RadzenText TextStyle="TextStyle.Overline" Style="color: #6B8FAD;">PIEZAS ROTAS</RadzenText>
                                    <RadzenText TextStyle="TextStyle.H6" Style="color: var(--rz-danger);">
                                        <b>@ordenSeleccionada.PiezasRotas</b>
                                    </RadzenText>
                                </RadzenStack>
                            </RadzenStack>
                        </RadzenColumn>
                    </RadzenRow>
                </RadzenCard>

                <div class="timer-strip-fuxa">
                    <div class="timer-val-big">@TimeSpan.FromSeconds(segundosTrabajo).ToString(@"hh\:mm\:ss")</div>
                    <div class="timer-status">
                        <div class="status-dot @(estaPausado ? "paused" : "running")"></div>
                        <RadzenText Style="color:#BDD7EE; margin:0;">@tipoActividad.ToUpper()</RadzenText>
                    </div>
                </div>

                @* Piezas fabricadas y rotas *@
                <RadzenRow Gap="1rem">
                    <RadzenColumn Size="12" SizeMD="6">
                        <div class="pcs-card-fuxa" style="background-color: #BDFFC6 ">
                            <RadzenText TextStyle="TextStyle.H5"><b>Piezas fabricadas</b></RadzenText>
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                                <RadzenButton Icon="remove" ButtonStyle="ButtonStyle.Danger" Click="() => ModificarPiezasFabricadas(-1)" />
                                <RadzenNumeric TValue="int" @bind-Value="piezasFabricadas" ShowUpDown="false" TextAlign="TextAlign.Center" Variant="Variant.Flat" Style="font-size: 2rem !important; font-weight: bold !important; width: 100%; background: transparent; border: none; box-shadow: none; color: #1A2E3F;" />
                                <RadzenButton Icon="add" ButtonStyle="ButtonStyle.Success" Click="() => ModificarPiezasFabricadas(1)" />
                            </RadzenStack>
                        </div>
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="6">
                        <div class="pcs-card-fuxa" style="background-color:#FFAC99">
                            <RadzenText TextStyle="TextStyle.H5"><b>Piezas rotas</b></RadzenText>
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                                <RadzenButton Icon="remove" ButtonStyle="ButtonStyle.Danger" Click="() => ModificarPiezasRotas(-1)" />
                                <RadzenNumeric TValue="int" @bind-Value="piezasRotas" ShowUpDown="false" TextAlign="TextAlign.Center" Variant="Variant.Flat" Style="font-size: 2rem !important; font-weight: bold !important; width: 100%; background: transparent; border: none; box-shadow: none; color: #721c24;" />
                                <RadzenButton Icon="add" ButtonStyle="ButtonStyle.Success" Click="() => ModificarPiezasRotas(1)" />
                            </RadzenStack>
                        </div>
                    </RadzenColumn>
                </RadzenRow>

                @* Ciclos Reales *@
                <RadzenRow Gap="1rem" class="rz-mb-4 rz-mt-2">
                    <RadzenColumn Size="12">
                        <div class="pcs-card-fuxa" style="background-color: #E6F2FF; border: 2px solid #7BB3D4;">
                            <RadzenText TextStyle="TextStyle.H5" Style="color: #1F4E79;"><b>Ciclos reales</b></RadzenText>
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Gap="3rem">
                                <RadzenButton Icon="remove" ButtonStyle="ButtonStyle.Info" Click="() => ciclosReales = Math.Max(0, ciclosReales - 1)" Size="ButtonSize.Large" />
                                <RadzenNumeric TValue="int" @bind-Value="ciclosReales" ShowUpDown="false" TextAlign="TextAlign.Center" Variant="Variant.Flat" Style="font-size: 2.5rem !important; font-weight: bold !important; width: 150px; background: transparent; border: none; box-shadow: none; color: #1F4E79;" />
                                <RadzenButton Icon="add" ButtonStyle="ButtonStyle.Info" Click="() => ciclosReales++" Size="ButtonSize.Large" />
                            </RadzenStack>
                        </div>
                    </RadzenColumn>
                </RadzenRow>

                <RadzenRow class="rz-mb-4">
                    <RadzenColumn Size="12">
                        <RadzenButton Text="AÑADIR MATERIALES AL TURNO" Icon="inventory_2" ButtonStyle="ButtonStyle.Info" Size="ButtonSize.Large" Click="AbrirDialogoMateriales" Style="height: 60px; font-weight: bold; border-radius: 12px; width: 100%; font-size: 1.1rem; background-color: #1F4E79;" />
                    </RadzenColumn>
                </RadzenRow>

                <RadzenRow Gap="1rem" class="rz-mb-4">
                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenButton Text="@(estaPausado ? "REANUDAR MÁQUINA" : "PAUSAR MÁQUINA")"
                                      Icon="@(estaPausado ? "play_arrow" : "pause")"
                                      ButtonStyle="ButtonStyle.Warning"
                                      Size="ButtonSize.Large"
                                      Click="PausarImputacion"
                                      Style="height: 75px; font-weight: bold; border-radius: 12px; width: 100%; font-size: 1.2rem;" />
                    </RadzenColumn>
                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenButton Text="GUARDAR TURNO (IMPUTAR)"
                                      Icon="save"
                                      ButtonStyle="ButtonStyle.Success"
                                      Size="ButtonSize.Large"
                                      Click="FinalizarImputacion"
                                      Style="height: 75px; font-weight: bold; border-radius: 12px; width: 100%; font-size: 1.2rem;" />
                    </RadzenColumn>
                </RadzenRow>

                <RadzenRow>
                    <RadzenColumn Size="12">
                        <RadzenButton Text="FINALIZAR OPERACIÓN DEFINITIVAMENTE" Icon="done_all" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Large" Click="CerrarOperacion" Style="height: 65px; font-weight: 900; border-radius: 12px; width: 100%; font-size: 1.2rem; background-color: #A8071A; letter-spacing: 1px;" />
                    </RadzenColumn>
                </RadzenRow>
            </RadzenStack>
        }
    </div>
</div>

<style>
    .terminal-container {
        background: #F0F4F8;
        min-height: 100vh;
    }

    .topbar {
        background: #1F4E79;
        color: white;
        padding: 1rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .clock-big {
        font-size: 2rem;
        font-weight: bold;
        font-family: monospace;
    }

    .machine-id {
        color: #7BB3D4;
        font-size: 0.8rem;
        letter-spacing: 2px;
    }

    .step-content {
        padding: 2rem;
        max-width: 1000px;
        margin: auto;
    }

    .instruction {
        text-align: left;
        margin-bottom: 2rem;
        color: #1F4E79;
        font-weight: bold;
        border-bottom: 2px solid #D5E3EF;
        padding-bottom: 10px;
    }

    .operario-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 1.5rem;
    }

    .operario-card {
        background: white;
        padding: 1.5rem;
        border-radius: 16px;
        text-align: center;
        cursor: pointer;
        box-shadow: var(--rz-shadow-3);
        transition: all 0.2s;
    }

        .operario-card:hover {
            border-color: #1F4E79;
            transform: translateY(-5px);
        }

    .avatar {
        width: 70px;
        height: 70px;
        background: #E9EEF4;
        color: #1F4E79;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
        font-size: 1.8rem;
        font-weight: bold;
    }

    .name {
        font-weight: bold;
        color: #1A2E3F;
        font-size: 1.1rem;
    }

    .surname {
        color: #757575;
        font-size: 0.9rem;
    }

    .timer-strip-fuxa {
        background: #1A2E3F;
        padding: 20px;
        border-radius: 12px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: white;
        margin-bottom: 1rem;
    }

    .timer-val-big {
        font-size: 3.5rem;
        font-weight: bold;
        font-family: monospace;
        letter-spacing: 2px;
    }

    .status-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        display: inline-block;
        margin-right: 8px;
    }

        .status-dot.running {
            background: #1D9E75;
            box-shadow: 0 0 10px #1D9E75;
        }

        .status-dot.paused {
            background: #EF9F27;
        }

    .act-grid-terminal {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr 1fr;
        gap: 10px;
        margin-bottom: 1rem;
    }

    .act-btn-fuxa {
        background: white;
        border: 1px solid #D5E3EF;
        padding: 15px;
