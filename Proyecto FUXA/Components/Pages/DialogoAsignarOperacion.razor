@using Proyecto_FUXA.Models
@using Proyecto_FUXA.Services
@using Radzen
@using Radzen.Blazor
@inject ServicioMaquina ServicioMaquina
@inject Radzen.DialogService DialogService
@inject NotificationService NotificationService

<RadzenStack Gap="1.5rem" class="rz-p-4">
    <RadzenText TextStyle="TextStyle.H6">Nueva Operación para: <b>@MaquinaCreacion.Nombre</b></RadzenText>

    <RadzenCard Variant="Variant.Flat">
        <RadzenStack Gap="1rem">
            <RadzenRow AlignItems="AlignItems.Center">
                <RadzenColumn Size="4">
                    <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-m-0">Código Operación</RadzenText>
                </RadzenColumn>
                <RadzenColumn Size="8">
                    <RadzenTextBox @bind-Value="modelo.CodigoOperacion" Style="width: 100%;" />
                </RadzenColumn>
            </RadzenRow>

            <RadzenRow AlignItems="AlignItems.Center">
                <RadzenColumn Size="4">
                    <RadzenText TextStyle="TextStyle.Subtitle2" class="rz-m-0">Ciclos Objetivo</RadzenText>
                </RadzenColumn>
                <RadzenColumn Size="8">
                    <RadzenNumeric @bind-Value="modelo.CiclosObjetivo" Style="width: 100%;" />
                </RadzenColumn>
            </RadzenRow>
        </RadzenStack>
    </RadzenCard>

    <RadzenText TextStyle="TextStyle.Subtitle1"><b>Seleccionar Orden de Fabricación:</b></RadzenText>
    <RadzenDataGrid AllowFiltering="true" AllowPaging="true" PageSize="5" AllowSorting="true"
                    Data="@ordenesActivas" TItem="Orden" SelectionMode="DataGridSelectionMode.Single"
                    @bind-Value="@selectedOrdenes" class="rz-shadow-2"
                    Change="@AlClicarEnFila">
        <Columns>
            <RadzenDataGridColumn TItem="Orden" Property="CodigoOrden" Title="Código" />
            <RadzenDataGridColumn TItem="Orden" Property="Producto" Title="Producto" />
            <RadzenDataGridColumn TItem="Orden" Property="Estado" Title="Estado" />
        </Columns>
    </RadzenDataGrid>

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="1rem">
        <RadzenButton Text="Cancelar" Click="() => DialogService.Close(false)" ButtonStyle="ButtonStyle.Light" />
        <RadzenButton Text="Iniciar Operación" Click="Guardar" Icon="play_arrow" 
                      ButtonStyle="ButtonStyle.Success" Disabled="@(selectedOrdenes?.Any() == false)" />
    </RadzenStack>
</RadzenStack>

@code {
    [Parameter] public Maquina MaquinaCreacion { get; set; }

    private List<Orden> ordenesActivas;
    private IList<Orden> selectedOrdenes;
    private NuevaOperacion modelo = new();

    protected override async Task OnInitializedAsync()
    {
        // Traemos solo las órdenes madre que estén "Abierta" o "Activa"
        var todas = await ServicioMaquina.GetAllOrdenes();
        ordenesActivas = todas.Where(o => o.Estado == "Abierta" || o.Estado == "Activa").ToList();
    }

    private async Task Guardar()
    {
        if (selectedOrdenes != null && selectedOrdenes.Any())
        {
            var ordenSeleccionada = selectedOrdenes.First();

            var operacion = new OperacionesOrden
            {
                IdOrden = ordenSeleccionada.Id,
                IdMaquina = MaquinaCreacion.Id,
                CodigoOperacion = modelo.CodigoOperacion, 
                CiclosObjetivo = modelo.CiclosObjetivo,   
                PiezasFabricadas = 0,                     
                PiezasRotas = 0,
                Estado = "Activa",                      
                FechaCreacion = DateTime.Now,
                IdSeccion = 1,                            
                IdOperacionMaestra = 1                    
            };

            var exito = await ServicioMaquina.InsertarOperacion(operacion);

            if (exito)
            {
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Success,
                    Summary = "Operación Confirmada",
                    Detail = "La orden se ha asignado correctamente",
                    Duration = 4000
                });
                DialogService.Close(true);
            }
            else
            {
                NotificationService.Notify(new NotificationMessage
                {
                    Severity = NotificationSeverity.Error,
                    Summary = "Error de Asignación",
                    Detail = "No se pudo conectar con la base de datos",
                    Duration = 4000
                });
            }
        }
    }
    private void AlClicarEnFila(object args)
    {
        // Forzamos la captura de la selección
        if (selectedOrdenes != null && selectedOrdenes.Any())
        {
            var seleccion = selectedOrdenes.First();

            // Asignamos el código
            modelo.CodigoOperacion = seleccion.CodigoOrden;

            // IMPORTANTE: Esta línea es la que hace que el texto aparezca arriba al instante
            StateHasChanged();
        }
    }

}