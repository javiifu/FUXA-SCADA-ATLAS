@using Proyecto_FUXA.Models
@using Proyecto_FUXA.Services
@using Radzen
@using Radzen.Blazor
@inject Radzen.DialogService DialogService
@inject ImputacionService ImputacionService
@inject NotificationService NotificationService

<div class="container">
    <RadzenText TextStyle="TextStyle.H6">Asignar trabajo a: @MaquinaCreacion.Nombre</RadzenText>
    <hr />

    <RadzenText TextStyle="TextStyle.Subtitle2" class="mt-3">Selecciona la Orden de Fabricación</RadzenText>
    <RadzenDropDown TValue="int" 
                    Data="@listaOrdenes" 
                    TextProperty="CodigoOrden" 
                    ValueProperty="Id" 
                    @bind-Value="idOrdenSeleccionada" 
                    Placeholder="Busca por código o producto..."
                    AllowFiltering="true"
                    FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                    Style="width: 100%;" />

    @if (idOrdenSeleccionada > 0)
    {
        <RadzenText TextStyle="TextStyle.Subtitle2" class="mt-4">Ciclos Objetivo para esta Máquina</RadzenText>
        <RadzenNumeric @bind-Value="ciclosParaEstaMaquina" Style="width: 100%;" Placeholder="Ej: 1000" />
        
        <p class="mt-2" style="font-size: 0.9rem; color: gray;">
            Se generará automáticamente el código: <b>@GenerarSufijoPrevisto()</b>
        </p>
    }

    <div class="mt-5" style="text-align: right;">
        <RadzenButton Text="Cancelar" Click="() => DialogService.Close(false)" ButtonStyle="ButtonStyle.Light" class="me-2" />
        <RadzenButton Text="ASIGNAR A MÁQUINA" Click="CrearOperacion" 
                      ButtonStyle="ButtonStyle.Success" 
                      Disabled="@(idOrdenSeleccionada == 0 || ciclosParaEstaMaquina <= 0)" />
    </div>
</div>

@code {
    [Parameter] public Maquina MaquinaCreacion { get; set; }
    
    List<Orden> listaOrdenes;
    int idOrdenSeleccionada;
    int ciclosParaEstaMaquina;

    protected override async Task OnInitializedAsync()
    {
        listaOrdenes = await ImputacionService.ObtenerOrdenesActivasParaAsignarAsync();
    }

    string GenerarSufijoPrevisto() {
        var orden = listaOrdenes.FirstOrDefault(o => o.Id == idOrdenSeleccionada);
        return orden != null ? $"{orden.CodigoOrden}-X" : "";
    }

    async Task CrearOperacion()
    {
        // Aquí llamaremos al método que crea la operación con el sufijo automático
        var exito = await ImputacionService.CrearNuevaOperacionAsync(idOrdenSeleccionada, MaquinaCreacion.Id, ciclosParaEstaMaquina);
        
        if (exito) {
            NotificationService.Notify(NotificationSeverity.Success, "Éxito", "Operación asignada correctamente.");
            DialogService.Close(true);
        }
    }
}